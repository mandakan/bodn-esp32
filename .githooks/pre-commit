#!/usr/bin/env bash
# Pre-commit hook: ensure docs/wiring.md is in sync with firmware/bodn/config.py.
#
# Only runs the check when config.py is staged for commit.
set -euo pipefail

STAGED=$(git diff --cached --name-only)

# --- Format check: run on any staged .py file ---
PY_FILES=$(echo "$STAGED" | grep '\.py$' || true)
# Filter to only existing files (deleted files would cause ruff to error)
EXISTING_PY=""
for f in $PY_FILES; do
    [ -f "$f" ] && EXISTING_PY="$EXISTING_PY $f"
done
if [ -n "$EXISTING_PY" ]; then
    if ! uv run ruff format --check $EXISTING_PY >/dev/null 2>&1; then
        echo ""
        echo "ERROR: Some staged Python files are not formatted."
        echo ""
        echo "  Run:  uv run ruff format firmware/ tests/"
        echo "  Then: re-stage the changed files."
        echo ""
        exit 1
    fi
fi

# --- Size-review check: run when firmware .py or board config is staged ---
# Hard fails when a disabled feature is imported (would ImportError on
# device). Warnings about enabled-but-unused features don't block commits —
# use `uv run python tools/size-review.py --strict` to gate on those too.
if echo "$STAGED" | grep -qE '^(firmware/.+\.py|boards/BODN_S3/(sdkconfig\.board|mpconfigboard\.(cmake|h)))$'; then
    if ! uv run python tools/size-review.py >/dev/null 2>&1; then
        echo ""
        echo "ERROR: size-review found imports that the custom firmware has disabled."
        echo ""
        echo "  See:  uv run python tools/size-review.py"
        echo ""
        exit 1
    fi
fi

# --- Web UI build check: regenerate web_ui.py if any tools/web/ source is staged ---
if echo "$STAGED" | grep -qE '^tools/web/(index\.html|style\.css|app\.js|login\.html)$'; then
    BEFORE=$(cat firmware/bodn/web_ui.py 2>/dev/null || true)
    uv run python tools/build-web-ui.py >/dev/null 2>&1
    AFTER=$(cat firmware/bodn/web_ui.py)
    if [ "$BEFORE" != "$AFTER" ]; then
        echo ""
        echo "ERROR: firmware/bodn/web_ui.py is out of sync with tools/web/ sources."
        echo ""
        echo "  The file has been regenerated for you. Just stage it:"
        echo ""
        echo "    git add firmware/bodn/web_ui.py"
        echo ""
        exit 1
    fi
fi

# --- Wiring sync check: only when config.py is being committed ---
if ! echo "$STAGED" | grep -q 'firmware/bodn/config\.py'; then
    exit 0
fi

# Save current wiring.md, regenerate, compare, restore
WIRING="docs/wiring.md"

if [ ! -f "$WIRING" ]; then
    echo ""
    echo "ERROR: $WIRING does not exist."
    echo ""
    echo "  Run:  uv run python tools/pinout.py --md"
    echo "  Then: git add $WIRING"
    echo ""
    exit 1
fi

BEFORE=$(cat "$WIRING")
uv run python tools/pinout.py --md >/dev/null 2>&1
AFTER=$(cat "$WIRING")

if [ "$BEFORE" != "$AFTER" ]; then
    echo ""
    echo "ERROR: docs/wiring.md is out of sync with firmware/bodn/config.py"
    echo ""
    echo "  The file has been regenerated for you. Just stage it:"
    echo ""
    echo "    git add docs/wiring.md"
    echo ""
    exit 1
fi
